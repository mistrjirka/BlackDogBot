{
  "name": "blackdogbot",
  "version": "0.1.0",
  "description": "Proactive AI assistant with jobs, skills, and scheduled tasks",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "scripts/launch.sh",
    "start:direct": "tsx src/index.ts",
    "dev": "scripts/launch.sh --watch",
    "dev:direct": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:core": "vitest run tests/integration/core",
    "test:jobs": "vitest run tests/integration/jobs",
    "test:fast": "vitest run tests/unit tests/integration/core",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "GPL-2.0",
  "dependencies": {
    "@adriangalilea/tghtml": "jsr:^0.2.3",
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@ai-sdk/provider": "^3.0.8",
    "@huggingface/transformers": "^3.4.0",
    "@lancedb/lancedb": "^0.17.0",
    "@lmstudio/sdk": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@types/turndown": "^5.0.6",
    "ai": "^6.0.0",
    "ajv": "^8.17.0",
    "better-sqlite3": "^11.0.0",
    "bottleneck": "^2.19.0",
    "croner": "^10.0.1",
    "discord.js": "^14.14.0",
    "dotenv": "^17.3.1",
    "grammy": "^1.35.0",
    "gray-matter": "^4.0.0",
    "js-tiktoken": "^1.0.21",
    "marked": "^17.0.3",
    "nanoid": "^5.1.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.0",
    "turndown": "^7.2.2",
    "yaml": "^2.7.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/socket.io": "^3.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ],
    "overrides": {}
  }
}
