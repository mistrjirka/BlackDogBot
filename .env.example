# AI Provider Configuration
# Use "openrouter" or "openai-compatible"
AI_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# OpenAI-compatible endpoint
OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
OPENAI_COMPATIBLE_API_KEY=your-key-here
OPENAI_COMPATIBLE_MODEL=llama3

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Logging
LOG_LEVEL=info

# Agent step limits
# Maximum number of LLM->tool->LLM cycles for the main chat agent (default: 150)
BETTERCLAW_MAIN_AGENT_MAX_STEPS=150

# Maximum number of LLM->tool->LLM cycles for the cron/scheduler agent (default: 100)
BETTERCLAW_CRON_AGENT_MAX_STEPS=100
